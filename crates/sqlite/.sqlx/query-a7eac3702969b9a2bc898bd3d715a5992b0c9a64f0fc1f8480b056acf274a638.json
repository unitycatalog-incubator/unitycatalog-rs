  "query": "\n            SELECT\n                id AS \"id!\",\n                label AS \"label!\",\n                name AS \"name!\",\n                properties,\n                created_at AS \"created_at!\",\n                updated_at\n            FROM objects\n            WHERE label = ?\n              AND namespace = ?\n              AND ( ? IS NULL OR id < ? )\n            ORDER BY id DESC\n            LIMIT ?\n            ",
