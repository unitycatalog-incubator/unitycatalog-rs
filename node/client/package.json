{
  "name": "@unitycatalog/client",
  "version": "0.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "napi": {
    "binaryName": "unitycatalog",
    "targets": [
      "aarch64-apple-darwin",
      "aarch64-linux-android",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "armv7-unknown-linux-gnueabihf",
      "armv7-unknown-linux-musleabihf",
      "x86_64-unknown-linux-musl",
      "universal-apple-darwin"
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@jest/globals": "^30.2.0",
    "@napi-rs/cli": "^3.5.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.4",
    "ava": "^7.0.0",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "shx": "^0.4.0",
    "tmp": "^0.2.3",
    "ts-jest": "^29.4.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.56.1"
  },
  "ava": {
    "timeout": "3m"
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "npm run build:debug && npm run tsc && shx cp unitycatalog/*.node dist/",
    "build:release": "napi build --platform --release",
    "build:debug": "napi build --platform --dts ../unitycatalog/native.d.ts --js ../unitycatalog/native.js",
    "tsc": "tsc -b",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "jest --verbose",
    "test:integration": "jest --config jest.integration.config.js --verbose --runInBand",
    "lint": "biome check . && biome format .",
    "lint-fix": "biome check --write && biome format --write .",
    "universal": "napi universal",
    "version": "napi version"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0"
  }
}
