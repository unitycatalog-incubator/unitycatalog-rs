---
/**
 * Renders a tabbed, synced code example from tagged snippet regions in the
 * examples/ source files. Uses Vite ?raw imports so Astro resolves files at
 * build time and HMR works in dev.
 *
 * Usage in MDX:
 *   import CodeExample from '../../components/CodeExample.astro';
 *   <CodeExample snippet="list_catalogs" />
 *
 * Snippet tagging convention (tag lines are stripped from rendered output):
 *   Rust/TypeScript:  // [snippet:name]  ...  // [/snippet:name]
 *   Python:           # [snippet:name]   ...  # [/snippet:name]
 */
import { Code, Tabs, TabItem } from "@astrojs/starlight/components";

// Vite ?raw imports — resolved at build time, proper HMR in dev
import rustCatalogs from "../../../examples/rust/src/catalogs.rs?raw";
import rustSchemas from "../../../examples/rust/src/schemas.rs?raw";
import rustTables from "../../../examples/rust/src/tables.rs?raw";
import rustVolumes from "../../../examples/rust/src/volumes.rs?raw";
import pyCatalogs from "../../../examples/python/catalogs.py?raw";
import pySchemas from "../../../examples/python/schemas.py?raw";
import pyTables from "../../../examples/python/tables.py?raw";
import pyVolumes from "../../../examples/python/volumes.py?raw";
import tsCatalogs from "../../../examples/typescript/examples/catalogs.ts?raw";
import tsSchemas from "../../../examples/typescript/examples/schemas.ts?raw";
import tsTables from "../../../examples/typescript/examples/tables.ts?raw";
import tsVolumes from "../../../examples/typescript/examples/volumes.ts?raw";

interface Props {
  snippet: string;
}

const { snippet } = Astro.props;

const SNIPPET_START = /^\s*(?:\/\/|#)\s*\[snippet:([a-z_]+)\]\s*$/;
const SNIPPET_END = /^\s*(?:\/\/|#)\s*\[\/snippet:([a-z_]+)\]\s*$/;

function parseSnippets(content: string): Map<string, string> {
  const lines = content.split("\n");
  const snippets = new Map<string, string>();
  let currentName: string | null = null;
  let currentLines: string[] = [];

  for (const line of lines) {
    const startMatch = line.match(SNIPPET_START);
    const endMatch = line.match(SNIPPET_END);

    if (startMatch) {
      currentName = startMatch[1];
      currentLines = [];
    } else if (endMatch && currentName === endMatch[1]) {
      const nonEmptyLines = currentLines.filter((l) => l.trim().length > 0);
      const minIndent = nonEmptyLines.reduce((min, l) => {
        const indent = l.match(/^(\s*)/)![1].length;
        return Math.min(min, indent);
      }, Infinity);
      const dedented =
        nonEmptyLines.length === 0
          ? currentLines
          : currentLines.map((l) => l.slice(minIndent));
      snippets.set(currentName, dedented.join("\n").trimEnd());
      currentName = null;
      currentLines = [];
    } else if (currentName !== null) {
      currentLines.push(line);
    }
  }

  return snippets;
}

type SnippetEntry = { rust?: string; python?: string; typescript?: string };

function buildRegistry(): Map<string, SnippetEntry> {
  const registry = new Map<string, SnippetEntry>();

  const add = (files: [string, string][], lang: keyof SnippetEntry) => {
    for (const [, content] of files) {
      for (const [name, code] of parseSnippets(content)) {
        if (!registry.has(name)) registry.set(name, {});
        registry.get(name)![lang] = code;
      }
    }
  };

  add(
    [
      ["catalogs.rs", rustCatalogs],
      ["schemas.rs", rustSchemas],
      ["tables.rs", rustTables],
      ["volumes.rs", rustVolumes],
    ],
    "rust",
  );
  add(
    [
      ["catalogs.py", pyCatalogs],
      ["schemas.py", pySchemas],
      ["tables.py", pyTables],
      ["volumes.py", pyVolumes],
    ],
    "python",
  );
  add(
    [
      ["catalogs.ts", tsCatalogs],
      ["schemas.ts", tsSchemas],
      ["tables.ts", tsTables],
      ["volumes.ts", tsVolumes],
    ],
    "typescript",
  );

  return registry;
}

const registry = buildRegistry();
const entry = registry.get(snippet);

if (!entry) {
  const available = [...registry.keys()].sort().join(", ");
  throw new Error(
    `Unknown snippet "${snippet}". Available snippets: ${available}`,
  );
}
---

<Tabs syncKey="language">
  {
    entry.rust && (
      <TabItem label="Rust">
        <Code code={entry.rust} lang="rust" />
      </TabItem>
    )
  }
  {
    entry.python && (
      <TabItem label="Python">
        <Code code={entry.python} lang="python" />
      </TabItem>
    )
  }
  {
    entry.typescript && (
      <TabItem label="TypeScript">
        <Code code={entry.typescript} lang="typescript" />
      </TabItem>
    )
  }
</Tabs>
